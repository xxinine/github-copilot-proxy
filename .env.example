# --- Shared secret used to encrypt GitHub tokens at rest (AES-256-GCM).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CPX_MASTER_KEY=please-change-me-to-a-64-char-hex-string-0000000000000000000000000000

# --- SQLite database file location (shared volume in compose).
CPX_DB_PATH=./data/cpx.db

# --- Bootstrap admin account (created on first start if no users exist).
CPX_ADMIN_USER=admin
CPX_ADMIN_PASS=admin

# --- Session signing secret for the control-plane web UI.
CPX_SESSION_SECRET=change-me-session-secret

# --- GitHub OAuth client id used for the Copilot device-flow login.
# Default is the well-known GitHub-for-VSCode/Copilot client id.
CPX_GITHUB_CLIENT_ID=Iv1.b507a08c87ecfe98

# --- Image used for each per-account proxy container.
CPX_PROXY_IMAGE=ghcr.io/voidsteed/copilot-proxy-api:latest

# --- Docker network that control-plane, gateway and account containers share.
CPX_DOCKER_NETWORK=cpx-net

# --- Internal port the copilot-proxy-api listens on inside each container.
CPX_PROXY_PORT=4141

# --- Ports exposed on the host.
CPX_CONTROL_PLANE_PORT=8080
CPX_GATEWAY_PORT=4000
